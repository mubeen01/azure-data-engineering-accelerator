{
    "name": "pl_load_generic_full",
    "properties": {
        "description": "Generic full load: truncate the staging table, copy the whole source file in, then run the object's load procedure. Called by pl_master_orchestrator for every metadata row where load_type = 'FULL'.",
        "activities": [
            {
                "name": "Copy_Source_To_Staging",
                "type": "Copy",
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 2,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "typeProperties": {
                    "source": {
                        "type": "DelimitedTextSource",
                        "storeSettings": {
                            "type": "AzureBlobFSReadSettings",
                            "recursive": false
                        },
                        "formatSettings": {
                            "type": "DelimitedTextReadSettings"
                        }
                    },
                    "sink": {
                        "type": "AzureSqlSink",
                        "preCopyScript": "@{concat('TRUNCATE TABLE [', pipeline().parameters.p_sink_schema, '].[', pipeline().parameters.p_sink_table, ']')}",
                        "writeBehavior": "insert"
                    },
                    "enableStaging": false
                },
                "inputs": [
                    {
                        "referenceName": "ds_generic_delimited_file",
                        "type": "DatasetReference",
                        "parameters": {
                            "container": "@pipeline().parameters.p_source_container",
                            "folderPath": "@pipeline().parameters.p_source_folder",
                            "fileName": "@pipeline().parameters.p_source_file"
                        }
                    }
                ],
                "outputs": [
                    {
                        "referenceName": "ds_generic_sql_table",
                        "type": "DatasetReference",
                        "parameters": {
                            "schemaName": "@pipeline().parameters.p_sink_schema",
                            "tableName": "@pipeline().parameters.p_sink_table"
                        }
                    }
                ]
            },
            {
                "name": "Run_Load_Procedure",
                "type": "SqlServerStoredProcedure",
                "dependsOn": [
                    {
                        "activity": "Copy_Source_To_Staging",
                        "dependencyConditions": ["Succeeded"]
                    }
                ],
                "policy": {
                    "timeout": "0.06:00:00",
                    "retry": 1,
                    "retryIntervalInSeconds": 30
                },
                "linkedServiceName": {
                    "referenceName": "ls_AdeaDW_AzureSqlDatabase",
                    "type": "LinkedServiceReference"
                },
                "typeProperties": {
                    "storedProcedureName": "@pipeline().parameters.p_load_procedure_name"
                }
            }
        ],
        "parameters": {
            "p_source_container": { "type": "string" },
            "p_source_folder": { "type": "string" },
            "p_source_file": { "type": "string" },
            "p_sink_schema": { "type": "string" },
            "p_sink_table": { "type": "string" },
            "p_load_procedure_name": { "type": "string" }
        },
        "annotations": []
    }
}
